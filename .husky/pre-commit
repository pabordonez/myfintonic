#!/usr/bin/env sh

echo "🔍 Running Quality Gates (pre-commit)..."

# Detectar cambios en el backend (apps/api)
if git diff --cached --name-only | grep -q "^apps/api/"; then
  echo "📦 Cambios detectados en apps/api. Ejecutando validaciones específicas..."

  # Gate 1: Linting (API)
  echo "📝 Checking code style (@myfintonic/api)..."
  npm run lint-quiet || {
    echo "❌ ESLint failed!"
    exit 1
  }

  # Gate 2: Unit Tests (API)
  echo "🧪 Running unit tests (@myfintonic/api)..."
  npm run test-silent || {
    echo "❌ Tests failed!"
    exit 1
  }

  # Gate 3: Build (API)
  echo "🔧 Checking Build (@myfintonic/api)..."
  npm run build || {
    echo "❌ Build failed!"
    exit 1
  }
fi

# Validar OpenAPI solo si hay cambios en la carpeta apps/api/docs
# git diff --cached --name-only: lista los archivos en staging
# grep -q "^apps/api/docs/": busca silenciosamente si alguno empieza por apps/api/docs/
if git diff --cached --name-only | grep -q "^apps/api/docs/"; then
  echo "🔍 Cambios detectados en la documentación API. Ejecutando validación..."
  
  # Ejecuta el comando de validación
  npm run api:validate
  
  # Captura el resultado. Si falla (código distinto de 0), aborta el commit.
  if [ $? -ne 0 ]; then
    echo "❌ Error: La validación de OpenAPI ha fallado. Corrige los errores antes de hacer commit."
    exit 1
  fi
fi



echo "✅ All pre-commit gates passed!"
