#!/usr/bin/env sh

echo "🔍 Running Quality Gates (pre-commit)..."

# Gate 1: Linting
echo "📝 Checking code style..."
npm run lint-quiet || {
  echo "❌ ESLint failed! Fix errors before committing."
  npm run lint
  exit 1
}

# Gate 2: Unit Tests
echo "🧪 Running unit tests..."
npm run test-silent || {
  echo "❌ Tests failed! All must pass."
  npm run test
  exit 1
}

# Gate 3: TypeScript Build
echo "🔧 Checking TypeScript..."
npm run build || {
  echo "❌ Build failed! Fix type errors."
  exit 1
}


# Validar OpenAPI solo si hay cambios en la carpeta docs/api
# git diff --cached --name-only: lista los archivos en staging
# grep -q "^docs/api/": busca silenciosamente si alguno empieza por docs/api/
if git diff --cached --name-only | grep -q "^docs/api/"; then
  echo "🔍 Cambios detectados en la documentación API. Ejecutando validación..."
  
  # Ejecuta el comando de validación
  npm run api:validate
  
  # Captura el resultado. Si falla (código distinto de 0), aborta el commit.
  if [ $? -ne 0 ]; then
    echo "❌ Error: La validación de OpenAPI ha fallado. Corrige los errores antes de hacer commit."
    exit 1
  fi
fi

echo "✅ All pre-commit gates passed!"