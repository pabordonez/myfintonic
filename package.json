{
  "name": "invoices-api",
  "version": "1.0.0",
  "description": "API para guardar y gestionar facturas",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test-silent": "vitest run --reporter=dot --silent",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint-quiet": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate --schema=src/infrastructure/persistence/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/infrastructure/persistence/prisma/schema.prisma",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "dotenv": "^16.4.7",
    "express": "^5.2.1"
  },
  "prisma": {
    "schema": "src/infrastructure/persistence/prisma/schema.prisma"
  }
}
