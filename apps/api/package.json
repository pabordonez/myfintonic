{
  "name": "@myfintonic/api",
  "version": "1.0.0",
  "private": true,
  "description": "API de gestión de activos financieros personales",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate && tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:silent": "vitest run --reporter=dot --silent",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:quiet": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "audit": "npm audit --audit-level=high",
    "db:generate": "prisma generate --schema=src/infrastructure/persistence/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/infrastructure/persistence/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=src/infrastructure/persistence/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/infrastructure/persistence/prisma/schema.prisma",
    "db:seed:local": "tsx src/infrastructure/persistence/prisma/local-seed.ts",
    "api:validate": "swagger-cli validate docs/api/openapi.yaml",
    "api:bundle": "swagger-cli bundle docs/api/openapi.yaml -o docs/api/openapi-bundled.yaml -t yaml",
    "clean": "rm -rf dist coverage node_modules"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@eslint/js": "^9.17.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "prisma": {
    "schema": "src/infrastructure/persistence/prisma/schema.prisma",
    "seed": "tsx src/infrastructure/persistence/prisma/seed-admin.ts"
  }
}
