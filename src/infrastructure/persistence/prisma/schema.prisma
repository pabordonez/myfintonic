// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums basados en tu diseño
enum ProductStatus {
  ACTIVE
  INACTIVE
  PAUSED
  EXPIRED
}

enum ProductType {
  CURRENT_ACCOUNT
  SAVINGS_ACCOUNT
  FIXED_TERM_DEPOSIT
  INVESTMENT_FUND
  STOCKS
}

enum Role {
  ADMIN
  USER
}

model Client {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  nickname  String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  products  FinancialProduct[]
  clientFinancialEntities ClientFinancialEntity[]
}

model FinancialEntity {
  id        String   @id @default(uuid())
  name      String   @unique
  
  products  FinancialProduct[]
  clientFinancialEntities ClientFinancialEntity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model ClientFinancialEntity {
  id                String   @id @default(uuid())
  balance           Decimal? @db.Decimal(15, 2)
  initialBalance    Decimal? @db.Decimal(15, 2)
  
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  financialEntityId String
  financialEntity   FinancialEntity @relation(fields: [financialEntityId], references: [id], onDelete: Cascade)
  
  valueHistory      ClientFinancialEntityValueHistory[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@unique([clientId, financialEntityId])
  @@index([clientId])
  @@index([financialEntityId])
}

// Modelo principal usando Single Table Inheritance
model FinancialProduct {
  id              String        @id // PREFIJO-UUID
  type            ProductType
  name            String
  financialEntityId String
  financialEntity FinancialEntity @relation(fields: [financialEntityId], references: [id])
  status          ProductStatus @default(ACTIVE)
  clientId        String        // UUID del cliente
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Campos específicos (Opcionales dependiendo del tipo)
  // Cuentas y Depósitos
  currentBalance       Decimal?  @db.Decimal(15, 2)
  monthlyInterestRate  Decimal?  @db.Decimal(5, 4)
  initialBalance       Decimal?  @db.Decimal(15, 2)
  initialDate          DateTime?
  annualInterestRate   Decimal?  @db.Decimal(5, 4)
  maturityDate         DateTime?
  interestPaymentFreq  String?

  // Fondos y Acciones
  numberOfUnits        Decimal?  @db.Decimal(15, 6) // Participaciones pueden tener muchos decimales
  netAssetValue        Decimal?  @db.Decimal(15, 2)
  numberOfShares       Decimal?  @db.Decimal(15, 2) // A veces hay acciones fraccionarias
  unitPurchasePrice    Decimal?  @db.Decimal(15, 2)
  currentMarketPrice   Decimal?  @db.Decimal(15, 2)

  // JSON para objetos complejos (fees)
  fees                 Json?

  // Relaciones
  valueHistory         ValueHistory[]
  transactions         ProductTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([clientId])
  @@index([type])
  @@index([financialEntityId])
}

model ValueHistory {
  id        Int      @id @default(autoincrement())
  date      DateTime
  value     Decimal  @db.Decimal(15, 2)
  previousValue Decimal? @db.Decimal(15, 2)
  
  productId String
  product   FinancialProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([date])
}

model ClientFinancialEntityValueHistory {
  id                      Int      @id @default(autoincrement())
  date                    DateTime
  value                   Decimal  @db.Decimal(15, 2)
  previousValue           Decimal? @db.Decimal(15, 2)
  
  clientFinancialEntityId String
  clientFinancialEntity   ClientFinancialEntity @relation(fields: [clientFinancialEntityId], references: [id], onDelete: Cascade)

  @@index([clientFinancialEntityId])
  @@index([date])
}

model ProductTransaction {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(15, 2)
  
  productId   String
  product     FinancialProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([date])
}